---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Jamal & Gabriela', description = "We're getting married — December 18, 2026" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | J &amp; G Wedding</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Italianno&family=Jost:wght@300;400;500&family=Mrs+Saint+Delafield&family=Pinyon+Script&family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Ruthie&family=Tangerine:wght@700&display=swap" rel="stylesheet" />
  <slot name="head" />
</head>
<body>

  <!-- ── Sticky Nav ── -->
  <div class="site-nav-wrap">
    <div class="nav-progress" id="navProgress"></div>
    <div class="nav-inner">
      <a class="nav-brand" id="navBrand" href={`${base}/`}>
        <span class="nav-brand-text">J &amp; G</span>
      </a>

      <ul class="nav-links" role="list">
        <li><a class="nav-link" href={`${base}/`}>Home</a></li>
        <li><a class="nav-link" href={`${base}/#venues`}>Ceremony &amp; Reception</a></li>
        <li><a class="nav-link" href={`${base}/#wedding-party`}>Wedding Party</a></li>
        <li><a class="nav-link" href={`${base}/#dress-code`}>Dress Code</a></li>
        <li><a class="nav-link" href={`${base}/#timeline`}>Timeline</a></li>
        <li><a class="nav-link" href={`${base}/#where-to-stay`}>Travel &amp; Stay</a></li>
        <li><a class="nav-link" href={`${base}/#gallery`}>Gallery</a></li>
        <li><a class="nav-link" href={`${base}/#rsvp`}>RSVP</a></li>
        <li><a class="nav-link" href={`${base}/#faq`}>Questions</a></li>
        <li><a class="nav-link" href={`${base}/#gifts`}>Gifts</a></li>
      </ul>

      <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu">
        <span></span><span></span><span></span>
      </button>
    </div>

    <!-- Mobile dropdown -->
    <nav id="mobileMenu" class="nav-mobile-menu" aria-label="Mobile navigation">
      <a href={`${base}/`}>Home</a>
      <a href={`${base}/#venues`}>Ceremony &amp; Reception</a>
      <a href={`${base}/#wedding-party`}>Wedding Party</a>
      <a href={`${base}/#dress-code`}>Dress Code</a>
      <a href={`${base}/#timeline`}>Timeline</a>
      <a href={`${base}/#where-to-stay`}>Travel &amp; Stay</a>
      <a href={`${base}/#gallery`}>Gallery</a>
      <a href={`${base}/#rsvp`}>RSVP</a>
      <a href={`${base}/#faq`}>Questions</a>
      <a href={`${base}/#gifts`}>Gifts</a>
    </nav>
  </div>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <img src={`${base}/photos/monogram.png`} alt="" class="footer-mono" aria-hidden="true" />
    <p class="footer-title">The Bustos</p>
    <p class="footer-date">December 18, 2026</p>
    <p class="footer-tagline">We can't wait to celebrate with you!</p>
    <p class="footer-contact">Questions? Email us at <span>thebustos2026@gmail.com</span></p>
  </footer>

  <!-- ── Mobile Sticky RSVP ── -->
  <button class="sticky-rsvp" id="stickyRsvp" aria-label="RSVP Now">RSVP Now</button>

  <!-- ── Lightbox (shared, populated by gallery JS) ── -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <button class="lb-close" id="lbClose" aria-label="Close lightbox">&#215;</button>
    <img class="lb-img" id="lbImg" src="" alt="" />
  </div>

  <script>
    // ── Nav Brand reveal via IntersectionObserver ──
    const brand = document.getElementById('navBrand');
    const hero  = document.querySelector('.hero');
    if (brand && hero) {
      const obs = new IntersectionObserver(
        ([entry]) => {
          brand.classList.toggle('visible', !entry.isIntersecting);
        },
        { threshold: 0.05 }
      );
      obs.observe(hero);
    }

    // ── Active nav link via IntersectionObserver ──
    const sections = document.querySelectorAll('section[id], div[id].hero');
    const navLinks  = document.querySelectorAll('.nav-link');

    const sectionIds = ['venues','wedding-party','dress-code','timeline','where-to-stay','gallery','rsvp','faq','gifts'];
    const sectionMap = new Map();
    sectionIds.forEach(id => {
      const el = document.getElementById(id);
      if (el) sectionMap.set(el, id);
    });

    const linkMap = new Map();
    navLinks.forEach(link => {
      const hash = new URL(link.href, location.href).hash.slice(1);
      if (hash) linkMap.set(hash, link);
    });

    const sectionObs = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          const id = sectionMap.get(entry.target);
          const link = id && linkMap.get(id);
          if (link) link.classList.toggle('active', entry.isIntersecting);
        });
      },
      { rootMargin: '-40% 0px -55% 0px' }
    );
    sectionMap.forEach((id, el) => sectionObs.observe(el));

    // ── Mobile hamburger ──
    const toggle = document.querySelector('.nav-toggle');
    const menu   = document.getElementById('mobileMenu');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        const open = menu.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(open));
        toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      });
      // close on link click
      menu.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          menu.classList.remove('open');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.setAttribute('aria-label', 'Open menu');
        });
      });
    }

    // ── Lightbox ──
    const lb    = document.getElementById('lightbox');
    const lbImg = document.getElementById('lbImg') as HTMLImageElement | null;
    const lbClose = document.getElementById('lbClose');

    function openLightbox(src: string, alt: string) {
      if (!lb || !lbImg) return;
      lbImg.src = src;
      lbImg.alt = alt;
      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
      if (!lb || !lbImg) return;
      lb.classList.remove('open');
      lbImg.src = '';
      document.body.style.overflow = '';
    }

    if (lbClose) lbClose.addEventListener('click', closeLightbox);
    if (lb) {
      lb.addEventListener('click', e => { if (e.target === lb) closeLightbox(); });
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && lb.classList.contains('open')) closeLightbox();
      });
    }

    // Expose globally for gallery items
    (window as any).__openLightbox = openLightbox;
  </script>

  <script is:inline>
  // ════════════════════════════════════════
  // MOTION SYSTEM
  // ════════════════════════════════════════
  (function () {
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── Scroll Reveal (minimal set) ──
    var revealObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          revealObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });

    function addReveal(el, cls, delay) {
      el.classList.add(cls || 'reveal');
      if (delay) el.style.setProperty('--reveal-delay', delay + 'ms');
      revealObs.observe(el);
    }

    // Section headings + ornaments
    document.querySelectorAll('.section-heading').forEach(function (el) { addReveal(el, 'reveal', 0); });
    document.querySelectorAll('.section-ornament').forEach(function (el) { addReveal(el, 'reveal', 100); });

    // Venue cards
    document.querySelectorAll('.venues-grid').forEach(function (grid) {
      grid.querySelectorAll('.venue-card').forEach(function (el, i) { addReveal(el, 'reveal', 150 + i * 130); });
    });

    // Polaroid photos
    document.querySelectorAll('.quote-polaroid').forEach(function (el, i) { addReveal(el, 'reveal', i * 120); });

    // Gallery items
    document.querySelectorAll('.gallery-grid').forEach(function (grid) {
      grid.querySelectorAll('.gallery-item').forEach(function (el, i) { addReveal(el, 'reveal', i * 40); });
    });

    // Timeline container only (for line-draw); items appear immediately
    var timeline = document.querySelector('.timeline');
    if (timeline) { addReveal(timeline, 'reveal', 0); }

    if (reduced) return;

    // ── Hero Parallax ──
    var heroSlides = document.querySelectorAll('.hero-slide');
    if (heroSlides.length) {
      var rafPending = false;
      function onParallaxScroll() {
        if (rafPending) return;
        rafPending = true;
        requestAnimationFrame(function () {
          var y = window.scrollY;
          heroSlides.forEach(function (slide) {
            slide.style.transform = 'translateY(' + (y * 0.4) + 'px)';
          });
          rafPending = false;
        });
      }
      window.addEventListener('scroll', onParallaxScroll, { passive: true });
    }

    // ── Hero Scroll Indicator Fade ──
    var heroEl = document.querySelector('.hero');
    var scrollIndicator = document.querySelector('.hero-scroll');
    if (heroEl && scrollIndicator) {
      var scrollFadeObs = new IntersectionObserver(function (entries) {
        scrollIndicator.style.opacity = entries[0].isIntersecting ? '0.5' : '0';
      }, { threshold: 0.05 });
      scrollFadeObs.observe(heroEl);
    }

    // ── Quote Polaroid Subtle Parallax ──
    var polA = document.querySelector('.quote-polaroid--a');
    var polB = document.querySelector('.quote-polaroid--b');
    var quoteSection = document.querySelector('.quote-section');
    if (polA && polB && quoteSection) {
      var polRaf = false;
      function onPolScroll() {
        if (polRaf) return;
        polRaf = true;
        requestAnimationFrame(function () {
          var rect = quoteSection.getBoundingClientRect();
          var center = rect.top + rect.height / 2;
          var offset = (window.innerHeight / 2 - center) * 0.06;
          polA.style.transform = 'rotate(-3deg) translateY(' + (offset * 0.9) + 'px)';
          polB.style.transform = 'rotate(2deg) translateY(' + (offset * 1.1) + 'px)';
          polRaf = false;
        });
      }
      window.addEventListener('scroll', onPolScroll, { passive: true });
    }

    // ── Nav Progress Bar ──
    var progressBar = document.getElementById('navProgress');
    if (progressBar) {
      var progRaf = false;
      function updateProgress() {
        if (progRaf) return;
        progRaf = true;
        requestAnimationFrame(function () {
          var docH = document.documentElement.scrollHeight - window.innerHeight;
          var pct = docH > 0 ? (window.scrollY / docH) * 100 : 0;
          progressBar.style.width = pct + '%';
          progRaf = false;
        });
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
    }

  })();

  // ── FAQ Accordion ──
  document.querySelectorAll('.faq-trigger').forEach(function (trigger) {
    trigger.addEventListener('click', function () {
      var item = trigger.closest('.faq-item');
      var answer = item.querySelector('.faq-answer');
      var isOpen = trigger.getAttribute('aria-expanded') === 'true';
      // close all
      document.querySelectorAll('.faq-trigger').forEach(function (t) {
        t.setAttribute('aria-expanded', 'false');
        var a = t.closest('.faq-item').querySelector('.faq-answer');
        if (a) a.classList.remove('open');
      });
      // open this one if it was closed
      if (!isOpen && answer) {
        trigger.setAttribute('aria-expanded', 'true');
        answer.classList.add('open');
      }
    });
  });

  // ── Sticky RSVP Button (mobile) ──
  var stickyRsvp = document.getElementById('stickyRsvp');
  if (stickyRsvp) {
    stickyRsvp.addEventListener('click', function () {
      var rsvpEl = document.getElementById('rsvp');
      if (rsvpEl) rsvpEl.scrollIntoView({ behavior: 'smooth' });
    });
    var heroElForRsvp = document.querySelector('.hero');
    var stickyRaf = false;
    function updateStickyRsvp() {
      if (stickyRaf) return;
      stickyRaf = true;
      requestAnimationFrame(function () {
        var rsvpEl = document.getElementById('rsvp');
        var heroH = heroElForRsvp ? heroElForRsvp.offsetHeight : 0;
        var pastHero = window.scrollY > heroH * 0.5;
        var atOrPastRsvp = rsvpEl ? window.scrollY >= rsvpEl.offsetTop - window.innerHeight * 0.6 : false;
        stickyRsvp.classList.toggle('visible', pastHero && !atOrPastRsvp);
        stickyRaf = false;
      });
    }
    window.addEventListener('scroll', updateStickyRsvp, { passive: true });
    updateStickyRsvp();
  }
  </script>

</body>
</html>
