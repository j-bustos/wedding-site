---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const heroSlides = [
  `${base}/photos/hero/7_251220-gj-74.jpg`,
  `${base}/photos/hero/4_251220-gj-92.jpeg`,
];

const galleryImages = [
  { src: `${base}/photos/Gallery/3_251220-gj-66.jpeg`,  alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/4_251220-gj-92.jpg`,   alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/5_251220-gj-73.jpg`,   alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/6_251220-gj-3.jpg`,    alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/8_251220-gj-75.jpg`,   alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/9_251220-gj-97.jpg`,   alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/10_251220-gj-6.jpg`,   alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/11_251220-gj-102.jpg`, alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/14_251220-gj-100.jpg`, alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/15_251220-gj-47.jpg`,  alt: 'Jamal and Gabriela' },
];
---
<BaseLayout title="Home">
  <link rel="preload" as="image" href={heroSlides[0]} fetchpriority="high" slot="head" />

  <!-- ════════════════════════════════
       HERO — Crossfade Carousel
       ════════════════════════════════ -->
  <div class="hero" id="hero">

    {heroSlides.map((src, i) => (
      <div
        class={`hero-slide${i === 0 ? ' active' : ''}`}
        style={`background-image:url('${src}')`}
        aria-hidden="true"
      />
    ))}

    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="hero-content">
      <p class="hero-eyebrow">The Wedding of</p>

      <h1 class="hero-title">The Bustos</h1>

      <div class="hero-divider" aria-hidden="true"></div>

      <p class="hero-date">December 18, 2026</p>
      <p class="hero-location">McAllen, TX</p>

      <div class="hero-countdown" aria-label="Countdown to the wedding">
        <div class="hero-countdown-unit">
          <span class="hero-countdown-number" id="cd-days">—</span>
          <span class="hero-countdown-label">Days</span>
        </div>
        <div class="hero-countdown-unit">
          <span class="hero-countdown-number" id="cd-hours">—</span>
          <span class="hero-countdown-label">Hours</span>
        </div>
        <div class="hero-countdown-unit">
          <span class="hero-countdown-number" id="cd-min">—</span>
          <span class="hero-countdown-label">Minutes</span>
        </div>
        <div class="hero-countdown-unit">
          <span class="hero-countdown-number" id="cd-sec">—</span>
          <span class="hero-countdown-label">Seconds</span>
        </div>
      </div>

      <a href="#rsvp" class="hero-rsvp-btn">RSVP Now</a>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span class="hero-scroll-label">Scroll</span>
      <svg width="16" height="22" viewBox="0 0 16 22" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M8 2v18M2 14l6 6 6-6"/>
      </svg>
    </div>

  </div>

  <!-- ── Welcome strip ── -->
  <div class="welcome-strip section-dark">
    <p class="welcome-text">We can't wait to celebrate with you. Here's everything you need to know.</p>
  </div>

  <!-- ── Quote section ── -->
  <div class="quote-section">
    <div class="quote-polaroids-wrap">
      <div class="quote-polaroid quote-polaroid--a">
        <img src={`${base}/photos/hero/1_251220-gj-50.jpg`} alt="Jamal and Gabriela" loading="lazy" />
      </div>
      <div class="quote-polaroid quote-polaroid--b">
        <img src={`${base}/photos/Gallery/5_251220-gj-73.jpg`} alt="Jamal and Gabriela" loading="lazy" />
      </div>
    </div>
  </div>

  <!-- ════════════════════════════════
       1. CEREMONY & RECEPTION (light linen)
       ════════════════════════════════ -->

  <section id="venues" class="section section-cream">
    <div class="section-inner-wide">
      <h2 class="section-heading">Ceremony &amp; Reception</h2>
      <div class="section-ornament"><span>✦</span></div>

      <div class="venues-grid">

        <!-- Ceremony -->
        <div id="ceremony" class="venue-card">
          <div class="venue-card-body">
            <div class="venue-card-header">
              <svg class="venue-icon" width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="1" y="3" width="14" height="12" rx="1.5" stroke="#1e3a2f" stroke-width="1.3"/>
                <line x1="1" y1="6.5" x2="15" y2="6.5" stroke="#1e3a2f" stroke-width="1.3"/>
                <line x1="4.5" y1="1" x2="4.5" y2="5" stroke="#1e3a2f" stroke-width="1.3" stroke-linecap="round"/>
                <line x1="11.5" y1="1" x2="11.5" y2="5" stroke="#1e3a2f" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              <p class="venue-label">Ceremony</p>
            </div>
            <p class="venue-time">3:00 PM</p>
            <div class="venue-name-row">
              <svg class="venue-pin" width="12" height="16" viewBox="0 0 12 16" fill="none" aria-hidden="true">
                <path d="M6 1.5C3.52 1.5 1.5 3.52 1.5 6c0 3.75 4.5 8.5 4.5 8.5s4.5-4.75 4.5-8.5c0-2.48-2.02-4.5-4.5-4.5z" stroke="#1e3a2f" stroke-width="1.3"/>
                <circle cx="6" cy="6" r="1.4" fill="#1e3a2f"/>
              </svg>
              <h3 class="venue-name">Holy Spirit Catholic Church</h3>
            </div>
            <address class="venue-address">
              2201 Martin Ave<br />
              McAllen, TX 78504
            </address>
            <a
              class="btn-directions"
              href="https://www.google.com/maps/search/?api=1&query=2201+Martin+Ave+McAllen+TX+78504"
              target="_blank"
              rel="noopener noreferrer"
            >Get Directions</a>
          </div>
          <div class="venue-card-img-wrap">
            <img
              src={`${base}/photos/Venue/Ceremony2.PNG`}
              alt="Holy Spirit Catholic Church"
              class="venue-photo-img"
              style="width:100%;height:auto"
            />
          </div>
        </div>

        <!-- Reception -->
        <div id="reception" class="venue-card">
          <div class="venue-card-body">
            <div class="venue-card-header">
              <svg class="venue-icon" width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="1" y="3" width="14" height="12" rx="1.5" stroke="#1e3a2f" stroke-width="1.3"/>
                <line x1="1" y1="6.5" x2="15" y2="6.5" stroke="#1e3a2f" stroke-width="1.3"/>
                <line x1="4.5" y1="1" x2="4.5" y2="5" stroke="#1e3a2f" stroke-width="1.3" stroke-linecap="round"/>
                <line x1="11.5" y1="1" x2="11.5" y2="5" stroke="#1e3a2f" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              <p class="venue-label">Reception</p>
            </div>
            <p class="venue-time">5:00 PM</p>
            <div class="venue-name-row">
              <svg class="venue-pin" width="12" height="16" viewBox="0 0 12 16" fill="none" aria-hidden="true">
                <path d="M6 1.5C3.52 1.5 1.5 3.52 1.5 6c0 3.75 4.5 8.5 4.5 8.5s4.5-4.75 4.5-8.5c0-2.48-2.02-4.5-4.5-4.5z" stroke="#1e3a2f" stroke-width="1.3"/>
                <circle cx="6" cy="6" r="1.4" fill="#1e3a2f"/>
              </svg>
              <h3 class="venue-name">Los Encinos Event Center</h3>
            </div>
            <address class="venue-address">
              17256 La Blanca Road<br />
              Donna, TX 78537
            </address>
            <a
              class="btn-directions"
              href="https://www.google.com/maps/search/?api=1&query=17256+La+Blanca+Road+McAllen+TX+78537"
              target="_blank"
              rel="noopener noreferrer"
            >Get Directions</a>
          </div>
          <div class="venue-card-img-wrap">
            <img
              src={`${base}/photos/Venue/Reception2.PNG`}
              alt="Los Encinos Event Center"
              class="venue-photo-img"
              style="width:100%;height:auto"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════
       2. WEDDING PARTY (light linen)
       ════════════════════════════════ -->

  <section id="wedding-party" class="section section-white">
    <div class="section-inner-wide">
      <h2 class="section-heading">Wedding Party</h2>
      <div class="section-ornament"><span>✦</span></div>

      <!-- Bride & Groom centered header -->
      <div class="wp-couple">
        <p class="wp-couple-name">Jamal Bustos</p>
        <div class="wp-couple-rule"></div>
        <p class="wp-couple-name">Gabriela Pedraza</p>
      </div>

      <!-- Two-column split: Groom's Side | Bride's Side -->
      <div class="wp-split">

        <!-- Left: Groom's Side -->
        <div class="wp-col wp-col--groom">
          <p class="wp-side-label">Groom's Side</p>

          <div class="wp-group">
            <p class="wp-role">Best Man</p>
            <p class="wp-name wp-name--honor">Anthony Huerta</p>
          </div>

          <div class="wp-group">
            <p class="wp-role">Parents of the Groom</p>
            <p class="wp-name">Issac Bustos</p>
            <p class="wp-name">Laurie Bustos</p>
          </div>

          <div class="wp-group">
            <p class="wp-role">Groomsmen</p>
            <p class="wp-name">Chris Buzzell</p>
            <p class="wp-name">Caleb Philbrick</p>
            <p class="wp-name">Logan Wright</p>
          </div>
        </div>

        <!-- Vertical center line -->
        <div class="wp-divider" aria-hidden="true"></div>

        <!-- Right: Bride's Side -->
        <div class="wp-col wp-col--bride">
          <p class="wp-side-label">Bride's Side</p>

          <div class="wp-group">
            <p class="wp-role">Maid of Honor</p>
            <p class="wp-name wp-name--honor">Briana Pedraza</p>
          </div>

          <div class="wp-group">
            <p class="wp-role">Parents of the Bride</p>
            <p class="wp-name">Adriana Pedraza</p>
            <p class="wp-name">Ray Pedraza</p>
          </div>

          <div class="wp-group">
            <p class="wp-role">Bridesmaids</p>
            <p class="wp-name">Lizeth Reyna</p>
            <p class="wp-name">Alexiz Sanchez</p>
            <p class="wp-name">Claryssa Trevino</p>
            <p class="wp-name">Sarah Vasquez</p>
          </div>
        </div>

      </div>

      <!-- Ring Bearer centered below columns -->
      <div class="wp-ring-bearer">
        <div class="wp-rb-rule"></div>
        <p class="wp-role wp-role--center">Ring Bearer</p>
        <p class="wp-name wp-name--rb">Kai Carter</p>
      </div>

      <!-- Padrinos on slightly darker linen background -->
      <div class="wp-padrinos">
        <p class="wp-padrinos-heading">Padrinos</p>
        <div class="wp-padrinos-ornament"><span>✦</span></div>
        <div class="wp-padrinos-grid">
          <div class="wp-padrino">
            <p class="wp-role wp-role--center">De Lazo</p>
            <p class="wp-name">Anthony Huerta</p>
            <p class="wp-name">Wendy Huerta</p>
          </div>
          <div class="wp-padrino">
            <p class="wp-role wp-role--center">De Arras</p>
            <p class="wp-name">Adriana Guajardo</p>
            <p class="wp-name">Elliot Guajardo</p>
          </div>
          <div class="wp-padrino">
            <p class="wp-role wp-role--center">De Cojines</p>
            <p class="wp-name">Amy Sojak</p>
            <p class="wp-name">Billy Gonzalez</p>
          </div>
          <div class="wp-padrino">
            <p class="wp-role wp-role--center">De Ramo</p>
            <p class="wp-name">Cristina Rosales</p>
            <p class="wp-name">Eddie Rosales</p>
          </div>
          <div class="wp-padrino">
            <p class="wp-role wp-role--center">De Biblia y Rosario</p>
            <p class="wp-name">Ito Alvarado</p>
            <p class="wp-name">Lilly Alvarado</p>
          </div>
          <div class="wp-padrino">
            <p class="wp-role wp-role--center">Primeros Padrinos</p>
            <p class="wp-name">Angie Pedraza</p>
            <p class="wp-name">David Pedraza</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Full-bleed photo divider ── -->
  <div class="party-photo-divider" aria-hidden="true">
    <img src={`${base}/photos/Gallery/3_251220-gj-66.jpeg`} alt="" loading="lazy" style="width:100%;height:100%" />
  </div>

  <!-- ════════════════════════════════
       3. DRESS CODE (light linen)
       ════════════════════════════════ -->

  <section id="dress-code" class="section section-cream">
    <div class="section-inner">
      <div class="dress-card">
        <h2 class="section-heading">Dress Code</h2>
        <div class="section-ornament"><span>✦</span></div>
        <p class="dress-subtitle">All Black Formal Attire</p>
        <p class="dress-code-text">
          We kindly ask all guests to wear all black.<br />
          Your elegance will set the perfect tone for our celebration.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════
       4. TIMELINE (light linen)
       ════════════════════════════════ -->

  <section id="timeline" class="section section-white">
    <div class="section-inner">
      <h2 class="section-heading">Timeline</h2>
      <div class="section-ornament"><span>✦</span></div>
      <div class="timeline">
        <div class="timeline-item">
          <span class="timeline-time">3:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Ceremony</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">4:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Cocktail Hour</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">5:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Reception Begins</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">5:30 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Dinner</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">6:30 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Toasts</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">7:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">First Dance</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">7:30 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Cake Cutting</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">8:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Dancing &amp; Celebration</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">11:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Send-off</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════
       5. WHERE TO STAY (light linen)
       ════════════════════════════════ -->

  <section id="where-to-stay" class="section section-cream">
    <div class="section-inner-wide">
      <h2 class="section-heading">Travel &amp; Accommodations</h2>
      <div class="section-ornament"><span>✦</span></div>
      <div class="travel-grid">

        <!-- Getting There -->
        <div class="travel-card">
          <svg class="travel-icon" width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
            <path d="M32 15.5l-11-4V5a2 2 0 00-4 0v6.5l-11 4v3.5l11-3V22l-3 2v3.5l5.5-1.5 5.5 1.5V24l-3-2v-5.5l11 3v-3.5z" fill="#1e3a2f"/>
          </svg>
          <h3 class="travel-card-heading">Getting There</h3>
          <div class="travel-airports">
            <p class="travel-primary-airport">
              McAllen Miller International Airport
              <span class="travel-iata">(MFE)</span>
            </p>
            <p class="travel-alt">Alternative option</p>
            <p class="travel-secondary-airport">
              Valley International Airport, Harlingen
              <span class="travel-iata">(HRL)</span>
            </p>
          </div>
        </div>

        <!-- Accommodations -->
        <div class="travel-card">
          <svg class="travel-icon" width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
            <rect x="4" y="12" width="28" height="22" rx="1" stroke="#1e3a2f" stroke-width="1.5"/>
            <path d="M8 12V8l10-5 10 5v4" stroke="#1e3a2f" stroke-width="1.5" fill="none"/>
            <rect x="15" y="24" width="6" height="10" fill="#1e3a2f" opacity="0.35"/>
            <rect x="7" y="17" width="5" height="5" rx="0.5" stroke="#1e3a2f" stroke-width="1.2"/>
            <rect x="24" y="17" width="5" height="5" rx="0.5" stroke="#1e3a2f" stroke-width="1.2"/>
          </svg>
          <h3 class="travel-card-heading">Accommodations</h3>
          <ul class="hotel-list">
            <li class="hotel-list-item">
              <a class="hotel-list-link" href="https://www.wyndhamhotels.com/laquinta/mcallen-texas/la-quinta-mcallen-convention-center/overview?CID=LC:6ysy27krtpcrqev:53221&iata=00093796" target="_blank" rel="noopener noreferrer">
                <span class="hotel-list-name">La Quinta Inn &amp; Suites McAllen</span>
                <span class="hotel-list-city">McAllen, TX</span>
                <span class="hotel-list-book">Book Now →</span>
              </a>
            </li>
            <li class="hotel-list-item">
              <a class="hotel-list-link" href="https://www.choicehotels.com/texas/mcallen/cambria-hotels/txg05?mc=llgoxxpx" target="_blank" rel="noopener noreferrer">
                <span class="hotel-list-name">Cambria Hotel McAllen</span>
                <span class="hotel-list-city">McAllen, TX</span>
                <span class="hotel-list-book">Book Now →</span>
              </a>
            </li>
            <li class="hotel-list-item">
              <a class="hotel-list-link" href="https://www.hilton.com/en/hotels/mfecoes-embassy-suites-mcallen-convention-center/?SEO_id=GMB-AMER-ES-MFECOES&y_source=1_MzM1NTMzOS03MTUtbG9jYXRpb24ud2Vic2l0ZQ%3D%3D" target="_blank" rel="noopener noreferrer">
                <span class="hotel-list-name">Embassy Suites by Hilton McAllen</span>
                <span class="hotel-list-city">McAllen, TX</span>
                <span class="hotel-list-book">Book Now →</span>
              </a>
            </li>
            <li class="hotel-list-item">
              <a class="hotel-list-link" href="https://www.hilton.com/en/hotels/mfemahu-home2-suites-mcallen/" target="_blank" rel="noopener noreferrer">
                <span class="hotel-list-name">Home2 Suites by Hilton McAllen</span>
                <span class="hotel-list-city">McAllen, TX</span>
                <span class="hotel-list-book">Book Now →</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Transportation -->
        <div class="travel-card">
          <svg class="travel-icon" width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
            <path d="M6 17l4-10h16l4 10" stroke="#1e3a2f" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <rect x="3" y="17" width="30" height="12" rx="2" stroke="#1e3a2f" stroke-width="1.5"/>
            <circle cx="10" cy="29" r="2.5" fill="#1e3a2f"/>
            <circle cx="26" cy="29" r="2.5" fill="#1e3a2f"/>
            <line x1="3" y1="22" x2="33" y2="22" stroke="#1e3a2f" stroke-width="1.2"/>
          </svg>
          <h3 class="travel-card-heading">Transportation</h3>
          <p class="travel-card-text">We recommend renting a car for the weekend. The venue is approximately 20 minutes from McAllen.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════
       6. GALLERY (light linen)
       ════════════════════════════════ -->

  <section id="gallery" class="section section-white">
    <div class="section-inner-wide">
      <h2 class="section-heading">Gallery</h2>
      <div class="section-ornament"><span>✦</span></div>
      <div class="gallery-grid" id="galleryGrid">
        {galleryImages.map((img) => (
          <div class="gallery-item" tabindex="0" role="button" aria-label={`View photo: ${img.alt}`}>
            <img src={img.src} alt={img.alt} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════
       7. RSVP (light linen)
       ════════════════════════════════ -->

  <section id="rsvp" class="section section-cream">
    <div class="section-inner">
      <h2 class="section-heading">Kindly Reply</h2>
      <div class="section-ornament"><span>✦</span></div>
      <p class="rsvp-sub">Kindly reply by November 1, 2026</p>
      <p class="rsvp-days" id="rsvpDays"></p>
      <!-- Replace href below with your Google Form URL when ready -->
      <a
        class="cashapp-btn"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
      >RSVP Now</a>
    </div>
  </section>

  <!-- ════════════════════════════════
       8. FAQ (dark green)
       ════════════════════════════════ -->

  <section id="faq" class="section section-dark">
    <div class="section-inner">
      <h2 class="section-heading">Questions</h2>
