---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Hero carousel photos (all 3 available in /public/photos/hero/)
// Note: 3_251220-gj-66.jpeg lives in /public/photos/Gallery/ — using 7_251220-gj-74.jpg as slide 2 instead.
const heroSlides = [
  `${base}/photos/hero/1_251220-gj-50.jpg`,
  `${base}/photos/hero/7_251220-gj-74.jpg`,
  `${base}/photos/hero/4_251220-gj-92.jpeg`,
];

const galleryImages = [
  { src: `${base}/photos/Gallery/3_251220-gj-66.jpeg`,  alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/4_251220-gj-92.jpg`,   alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/5_251220-gj-73.jpg`,   alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/6_251220-gj-3.jpg`,    alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/8_251220-gj-75.jpg`,   alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/9_251220-gj-97.jpg`,   alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/10_251220-gj-6.jpg`,   alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/11_251220-gj-102.jpg`, alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/12_251220-gj-58.jpg`,  alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/13_251220-gj-81.jpg`,  alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/14_251220-gj-100.jpg`, alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/15_251220-gj-47.jpg`,  alt: 'Jamal and Gabriela' },
  { src: `${base}/photos/Gallery/16_251220-gj-43.jpg`,  alt: 'Jamal and Gabriela' },
];
---
<BaseLayout title="Home">

  <!-- ════════════════════════════════
       HERO — Crossfade Carousel
       ════════════════════════════════ -->
  <div class="hero" id="hero">

    {heroSlides.map((src, i) => (
      <div
        class={`hero-slide${i === 0 ? ' active' : ''}`}
        style={`background-image:url('${src}')`}
        aria-hidden="true"
      />
    ))}

    <div class="hero-overlay" aria-hidden="true"></div>

    <div class="hero-content">
      <p class="hero-eyebrow">The Wedding of</p>

      <h1 class="hero-title">The Bustos</h1>

      <div class="hero-divider" aria-hidden="true"></div>

      <p class="hero-date">December 18, 2026</p>
      <p class="hero-location">McAllen, TX</p>

      <div class="hero-countdown" aria-label="Countdown to the wedding">
        <div class="hero-countdown-unit">
          <span class="hero-countdown-number" id="cd-days">—</span>
          <span class="hero-countdown-label">Days</span>
        </div>
        <div class="hero-countdown-unit">
          <span class="hero-countdown-number" id="cd-hours">—</span>
          <span class="hero-countdown-label">Hours</span>
        </div>
        <div class="hero-countdown-unit">
          <span class="hero-countdown-number" id="cd-min">—</span>
          <span class="hero-countdown-label">Minutes</span>
        </div>
        <div class="hero-countdown-unit">
          <span class="hero-countdown-number" id="cd-sec">—</span>
          <span class="hero-countdown-label">Seconds</span>
        </div>
      </div>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span class="hero-scroll-label">Scroll</span>
      <svg width="16" height="22" viewBox="0 0 16 22" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M8 2v18M2 14l6 6 6-6"/>
      </svg>
    </div>

  </div>

  <!-- ── Welcome strip ── -->
  <div class="welcome-strip section-cream">
    <p class="welcome-text">We can't wait to celebrate with you. Here's everything you need to know.</p>
  </div>

  <!-- ════════════════════════════════
       1. CEREMONY & RECEPTION (cream)
       ════════════════════════════════ -->
  <hr class="section-rule" aria-hidden="true" />

  <section id="venues" class="section section-cream">
    <div class="section-inner-wide">
      <h2 class="section-heading">Ceremony &amp; Reception</h2>
      <div class="section-ornament"><span>✦</span></div>

      <div class="venues-grid">

        <!-- Ceremony -->
        <div id="ceremony" class="venue-card">
          <div class="venue-photo-frame">
            <img
              src={`${base}/photos/Venue/Ceremony.PNG`}
              alt="Holy Spirit Catholic Church"
              class="venue-photo-img"
            />
          </div>
          <p class="venue-label">Ceremony · 3:00 PM</p>
          <h3 class="venue-name">Holy Spirit Catholic Church</h3>
          <address class="venue-address">
            2201 Martin Ave<br />
            McAllen, TX 78504
          </address>
          <a
            class="btn-directions"
            href="https://www.google.com/maps/search/?api=1&query=2201+Martin+Ave+McAllen+TX+78504"
            target="_blank"
            rel="noopener noreferrer"
          >Get Directions</a>
        </div>

        <!-- Reception -->
        <div id="reception" class="venue-card">
          <div class="venue-photo-frame">
            <img
              src={`${base}/photos/Venue/Reception.PNG`}
              alt="Los Encinos Event Center"
              class="venue-photo-img"
            />
          </div>
          <p class="venue-label">Reception · 5:00 PM</p>
          <h3 class="venue-name">Los Encinos Event Center</h3>
          <address class="venue-address">
            17256 La Blanca Road<br />
            McAllen, TX 78537
          </address>
          <a
            class="btn-directions"
            href="https://www.google.com/maps/search/?api=1&query=17256+La+Blanca+Road+McAllen+TX+78537"
            target="_blank"
            rel="noopener noreferrer"
          >Get Directions</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════
       2. WEDDING PARTY (white)
       ════════════════════════════════ -->
  <hr class="section-rule" aria-hidden="true" />

  <section id="wedding-party" class="section section-white">
    <div class="section-inner-wide">
      <h2 class="section-heading">Wedding Party</h2>
      <div class="section-ornament"><span>✦</span></div>
      <div class="party-layout">

        <!-- Couple -->
        <div class="party-couple">
          <div class="party-couple-half">
            <p class="party-role-label">Groom</p>
            <p class="party-couple-name">Jamal Bustos</p>
          </div>
          <div class="party-couple-half">
            <p class="party-role-label">Bride</p>
            <p class="party-couple-name">Gabriela Pedraza</p>
          </div>
        </div>

        <!-- Parents -->
        <div class="party-two-col">
          <div class="party-group">
            <p class="party-role-label">Parents of the Groom</p>
            <ul class="party-name-list">
              <li>Issac Bustos</li>
              <li>Laurie Bustos</li>
            </ul>
          </div>
          <div class="party-group">
            <p class="party-role-label">Parents of the Bride</p>
            <ul class="party-name-list">
              <li>Ray Pedraza</li>
              <li>Adriana Pedraza</li>
            </ul>
          </div>
        </div>

        <!-- Honor attendants -->
        <div class="party-featured-pair">
          <div class="party-featured-card party-featured-card--fixed">
            <p class="party-role-label">Best Man</p>
            <p class="party-featured-name">Anthony Huerta</p>
          </div>
          <div class="party-featured-card">
            <p class="party-role-label">Maid of Honor</p>
            <p class="party-featured-name">Briana Pedraza</p>
          </div>
        </div>

        <!-- Groomsmen & Bridesmaids — sorted alphabetically by last name -->
        <div class="party-two-col">
          <div class="party-group">
            <p class="party-role-label">Groomsmen</p>
            <ul class="party-name-list">
              <li>Chris Buzzell</li>
              <li>Caleb Philbrick</li>
              <li>Logan Wright</li>
            </ul>
          </div>
          <div class="party-group">
            <p class="party-role-label">Bridesmaids</p>
            <ul class="party-name-list">
              <li>Lizeth Reyna</li>
              <li>Alexiz Sanchez</li>
              <li>Claryssa Trevino</li>
              <li>Sarah Vasquez</li>
            </ul>
          </div>
        </div>

        <!-- Ring Bearer -->
        <div class="party-single">
          <p class="party-role-label">Ring Bearer</p>
          <p class="party-single-name">Kai Carter</p>
        </div>

        <!-- Padrinos -->
        <div>
          <p class="party-padrinos-label">Padrinos</p>
          <div class="party-padrinos-rule"><span>✦</span></div>
          <div class="padrinos-grid">
            <div class="padrino-group">
              <p class="padrino-role">Padrinos de Lazo</p>
              <p class="padrino-names">Wendy Huerta<br />Anthony Huerta</p>
            </div>
            <div class="padrino-group">
              <p class="padrino-role">Padrinos de Arras</p>
              <p class="padrino-names">Elliot Guajardo<br />Adriana Guajardo</p>
            </div>
            <div class="padrino-group">
              <p class="padrino-role">Padrinos de Cojines</p>
              <p class="padrino-names">Billy Gonzalez<br />Amy Sojak</p>
            </div>
            <div class="padrino-group">
              <p class="padrino-role">Padrinos de Ramo</p>
              <p class="padrino-names">Eddie Rosales<br />Cristina Rosales</p>
            </div>
            <div class="padrino-group">
              <p class="padrino-role">Padrinos de Biblia y Rosario</p>
              <p class="padrino-names">Ito Alvarado<br />Lilly Alvarado</p>
            </div>
            <div class="padrino-group">
              <p class="padrino-role">Primeros Padrinos</p>
              <p class="padrino-names">David Pedraza<br />Angie Pedraza</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Christmas accent #1 (between Wedding Party & Dress Code) -->
  <div class="christmas-accent" role="separator" aria-hidden="true">
    <img src={`${base}/photos/Christmas Detail/Untitled design (2).png`} alt="" />
  </div>

  <!-- ════════════════════════════════
       3. DRESS CODE (cream)
       ════════════════════════════════ -->
  <hr class="section-rule" aria-hidden="true" />

  <section id="dress-code" class="section section-cream">
    <div class="section-inner">
      <h2 class="section-heading">Dress Code</h2>
      <div class="section-ornament"><span>✦</span></div>
      <p class="dress-code-text">
        We kindly ask all guests to wear all black.<br />
        Your elegance will set the perfect tone for our celebration.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════
       4. TIMELINE (white)
       ════════════════════════════════ -->
  <hr class="section-rule" aria-hidden="true" />

  <section id="timeline" class="section section-white">
    <div class="section-inner">
      <h2 class="section-heading">Day Of</h2>
      <div class="section-ornament"><span>✦</span></div>
      <div class="timeline">
        <div class="timeline-item">
          <span class="timeline-time">3:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Ceremony</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">4:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Cocktail Hour</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">5:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Reception Begins</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">5:30 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Dinner</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">6:30 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Toasts</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">7:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">First Dance</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">7:30 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Cake Cutting</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">8:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Dancing &amp; Celebration</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-time">11:00 PM</span>
          <div class="timeline-dot-wrap"><div class="timeline-dot"></div></div>
          <span class="timeline-event">Send-off</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════
       5. WHERE TO STAY (cream)
       ════════════════════════════════ -->
  <hr class="section-rule" aria-hidden="true" />

  <section id="where-to-stay" class="section section-cream">
    <div class="section-inner-wide">
      <h2 class="section-heading">Where to Stay</h2>
      <div class="section-ornament"><span>✦</span></div>
      <div class="hotels-grid">

        <div class="hotel-card">
          <p class="hotel-name">La Quinta Inn &amp; Suites<br />McAllen Convention Center</p>
          <a
            class="btn-hotel"
            href="https://www.wyndhamhotels.com/laquinta/mcallen-texas/la-quinta-mcallen-convention-center/overview?CID=LC:6ysy27krtpcrqev:53221&iata=00093796"
            target="_blank" rel="noopener noreferrer"
          >Check Availability</a>
        </div>

        <div class="hotel-card">
          <p class="hotel-name">Cambria Hotel<br />McAllen Convention Center</p>
          <a
            class="btn-hotel"
            href="https://www.choicehotels.com/texas/mcallen/cambria-hotels/txg05?mc=llgoxxpx"
            target="_blank" rel="noopener noreferrer"
          >Check Availability</a>
        </div>

        <div class="hotel-card">
          <p class="hotel-name">Embassy Suites by Hilton<br />McAllen Convention Center</p>
          <a
            class="btn-hotel"
            href="https://www.hilton.com/en/hotels/mfecoes-embassy-suites-mcallen-convention-center/?SEO_id=GMB-AMER-ES-MFECOES&y_source=1_MzM1NTMzOS03MTUtbG9jYXRpb24ud2Vic2l0ZQ%3D%3D"
            target="_blank" rel="noopener noreferrer"
          >Check Availability</a>
        </div>

        <div class="hotel-card">
          <p class="hotel-name">Tru by Hilton<br />Edinburg</p>
          <a
            class="btn-hotel"
            href="https://www.hilton.com/en/hotels/mfeebru-tru-edinburg/?SEO_id=GMB-AMER-RU-MFEEBRU&y_source=1_MTQ5MzAzOTktNzE1LWxvY2F0aW9uLndlYnNpdGU%3D"
            target="_blank" rel="noopener noreferrer"
          >Check Availability</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Christmas accent #2 (between Where to Stay & Gallery) -->
  <div class="christmas-accent" role="separator" aria-hidden="true">
    <img src={`${base}/photos/Christmas Detail/Untitled design (2).png`} alt="" />
  </div>

  <!-- ════════════════════════════════
       6. GALLERY (white)
       ════════════════════════════════ -->
  <hr class="section-rule" aria-hidden="true" />

  <section id="gallery" class="section section-white">
    <div class="section-inner-wide">
      <h2 class="section-heading">Gallery</h2>
      <div class="section-ornament"><span>✦</span></div>
      <div class="gallery-grid" id="galleryGrid">
        {galleryImages.map((img) => (
          <div class="gallery-item" tabindex="0" role="button" aria-label={`View photo: ${img.alt}`}>
            <img src={img.src} alt={img.alt} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
