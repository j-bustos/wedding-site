    <div class="section-inner">
      <h2 class="section-heading">RSVP</h2>
      <div class="section-ornament"><span>✦</span></div>
      <p class="rsvp-sub">Kindly reply by November 1, 2026</p>
      <div class="rsvp-embed">
        <!-- PASTE GOOGLE FORM EMBED SRC HERE -->
        <iframe
          src=""
          frameborder="0"
          class="rsvp-iframe"
          title="RSVP Form"
          marginheight="0"
          marginwidth="0"
